import path from 'path';
import { defineConfig, loadEnv } from 'vite';
import react from '@vitejs/plugin-react';
import tailwindcss from '@tailwindcss/vite';

const netlifyFunctionDevPlugin = () => ({
  name: 'netlify-function-dev',
  configureServer(server: any) {
    server.middlewares.use(async (req: any, res: any, next: any) => {
      if (req.url && req.url.startsWith('/.netlify/functions/gemini-comment')) {
        if (req.method === 'OPTIONS') {
          res.writeHead(200, {
            'Access-Control-Allow-Origin': '*',
            'Access-Control-Allow-Headers': 'Content-Type',
            'Access-Control-Allow-Methods': 'POST, OPTIONS',
            'Content-Type': 'application/json',
          });
          res.end();
          return;
        }

        if (req.method === 'POST') {
          try {
            let body = '';
            await new Promise<void>((resolve, reject) => {
              req.on('data', (chunk: any) => {
                body += chunk;
              });
              req.on('end', () => resolve());
              req.on('error', (err: any) => reject(err));
            });

            // Dynamically load the TypeScript function inside the server context
            const module = await server.ssrLoadModule('/netlify/functions/gemini-comment.ts');
            
            const event = {
              httpMethod: 'POST',
              body: body,
              headers: req.headers,
              queryStringParameters: {},
              path: req.url,
            };

            const context = {};
            const result = await module.handler(event, context);

            res.writeHead(result.statusCode || 200, {
              'Access-Control-Allow-Origin': '*',
              'Access-Control-Allow-Headers': 'Content-Type',
              'Access-Control-Allow-Methods': 'POST, OPTIONS',
              'Content-Type': 'application/json',
              ...(result.headers || {}),
            });
            res.end(result.body || '');
            return;
          } catch (error: any) {
            console.error('Error in local Netlify Function emulation:', error);
            res.writeHead(500, { 'Content-Type': 'application/json' });
            res.end(JSON.stringify({
              error: 'LOCAL_DEV_NETLIFY_FUNCTION_ERROR',
              message: error.message || String(error),
            }));
            return;
          }
        }
      }
      next();
    });
  }
});

export default defineConfig(({ mode }) => {
    const env = loadEnv(mode, '.', '');
    return {
      server: {
        port: 3000,
        host: '0.0.0.0',
      },
      plugins: [react(), tailwindcss(), netlifyFunctionDevPlugin()],
      define: {
        'process.env.API_KEY': JSON.stringify(env.GEMINI_API_KEY),
        'process.env.GEMINI_API_KEY': JSON.stringify(env.GEMINI_API_KEY)
      },
      resolve: {
        alias: {
          '@': path.resolve(__dirname, '.'),
        }
      }
    };
});
